#!/bin/bash
# post-commit hook: keeps .claude/skills/deep-seo-audit/ in sync with
# the root source files after every commit.

REPO_ROOT="$(git rev-parse --show-toplevel)"
INSTALL_DIR="$REPO_ROOT/.claude/skills/deep-seo-audit"

# Files to sync (source path relative to repo root)
SYNC_FILES=(
  "SKILL.md"
  "README.md"
  "assets/report-template.md"
  "references/page-type-signals.md"
  "references/cwv-thresholds.md"
  "references/eeat-checklist.md"
  "references/google-helpful-content.md"
  "scripts/lighthouse_audit.sh"
  "scripts/generate_docx.js"
)

SYNCED=0

for FILE in "${SYNC_FILES[@]}"; do
  SRC="$REPO_ROOT/$FILE"
  DEST="$INSTALL_DIR/$FILE"

  [ -f "$SRC" ] || continue

  mkdir -p "$(dirname "$DEST")"

  if [ ! -f "$DEST" ] || [ "$SRC" -nt "$DEST" ]; then
    cp "$SRC" "$DEST"
    SYNCED=$((SYNCED + 1))
    echo "  synced: $FILE"
  fi
done

[ $SYNCED -gt 0 ] && echo "✅ post-commit: synced $SYNCED file(s) to .claude/skills/deep-seo-audit/"
